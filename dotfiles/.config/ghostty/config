# Theme
# theme = Gruvbox Material Dark
# background = 141617 

# Font
font-style = Regular
font-size = 13
window-inherit-font-size = true
font-family-italic = "Victor Mono"
font-family-bold-italic = "Victor Mono"
font-family = "CaskaydiaCove Nerd Font"
font-family-bold = "CaskaydiaCove Nerd Font"

# Window
title = "ghostty"
fullscreen = false
gtk-titlebar = false
window-decoration = false
window-theme = dark
macos-titlebar-style = hidden
window-padding-x = 5
window-padding-y = 5
confirm-close-surface=false
resize-overlay = never
app-notifications = no-clipboard-copy, no-config-reload
faint-opacity = 0.9

# Shell
command = "/usr/bin/tmux"
shell-integration = zsh
copy-on-select = true

# Slowdown mouse scrolling
mouse-scroll-multiplier = 0.95

# Fix general slowness on hyprland (https://github.com/ghostty-org/ghostty/discussions/3224)
async-backend = epoll

# Others
desktop-notifications = false

background = #0f1a14
foreground = #a8e6a1
cursor-color = #cddc39
cursor-text = #0f1a14

palette = 0=#1e2a24
palette = 1=#e06c75
palette = 2=#6bbf7a
palette = 3=#d7ba7d
palette = 4=#5fa9a8
palette = 5=#c678dd
palette = 6=#56b6c2
palette = 7=#e6e6d6

palette = 8=#3a4a3d
palette = 9=#f28b82
