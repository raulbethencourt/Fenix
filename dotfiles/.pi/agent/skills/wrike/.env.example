# Wrike Connector Skill — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# ------------------------------------------------------------------
# Required
# ------------------------------------------------------------------

# Permanent access token from Wrike → Profile → Apps & Integrations → API
WRIKE_ACCESS_TOKEN=your_permanent_token_here

# ------------------------------------------------------------------
# Optional (defaults shown)
# ------------------------------------------------------------------

# API base URL. Change to https://app-eu.wrike.com/api/v4 for EU data center.
WRIKE_BASE_URL=https://www.wrike.com/api/v4
